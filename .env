# ===========================
# OpexAI Environment Variables
# ===========================

# Port to expose the application on the host machine
APP_PORT=80

# Backend
NODE_ENV=production
PORT=3001
HOST=0.0.0.0
DATABASE_PATH=./data/opex.db
CORS_ORIGIN=http://localhost,http://localhost:3001

# Frontend (build-time only — baked into the JS bundle)
VITE_API_BASE_URL=/api
